*
!.gitignore

# Sempertex cluster swatches have no CDN — keep them in the repo so production
# gets them via deploy instead of needing an out-of-band SCP.
!color-images/
color-images/*
!color-images/sempertex/
color-images/sempertex/*
!color-images/sempertex/clusters/
!color-images/sempertex/clusters/*

# Decomex single-balloon images are pre-downloaded from Shopify collection pages
# and committed so the seeder can reference them without CDN calls.
!color-images/decomex/
color-images/decomex/*
!color-images/decomex/singles/
!color-images/decomex/singles/*
